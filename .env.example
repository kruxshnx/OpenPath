# Copy to .env and fill in. The defaults match docker-compose.yml for local dev.

# --- Database (matches docker-compose.yml) ---
DATABASE_URL="postgresql://openpath:openpath@localhost:5432/openpath?schema=public"

# --- Redis / BullMQ queue ---
REDIS_URL="redis://localhost:6379"

# --- API (NestJS) ---
API_PORT=4000
WEB_ORIGIN="http://localhost:3000"

# --- Web (Next.js) ---
API_URL="http://localhost:4000"

# --- GitHub OAuth app (create at https://github.com/settings/developers) ---
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# Personal access token for the ingestion worker (classic, read-only public_repo scope)
GITHUB_TOKEN=""

# --- Auth secrets (generate each with: openssl rand -base64 32) ---
JWT_SECRET="change-me"          # signs the app JWT the API issues/verifies
AUTH_SECRET="change-me"         # NextAuth/Auth.js v5 session secret (web)
ENCRYPTION_KEY="change-me"      # AES-256-GCM key for stored GitHub tokens (API)

# --- ML service (FastAPI) ---
ML_SERVICE_URL="http://localhost:8000"
