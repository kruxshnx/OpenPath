# Copy to .env and fill in. The defaults match docker-compose.yml for local dev.

# --- Database (matches docker-compose.yml) ---
DATABASE_URL="postgresql://openpath:openpath@localhost:5432/openpath?schema=public"

# --- Redis / BullMQ queue ---
REDIS_URL="redis://localhost:6379"

# --- API (NestJS) ---
API_PORT=4000
WEB_ORIGIN="http://localhost:3000"

# --- Web (Next.js) ---
API_URL="http://localhost:4000"

# --- GitHub OAuth app (create at https://github.com/settings/developers) ---
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# Personal access token for the ingestion worker (classic, read-only public_repo scope)
GITHUB_TOKEN=""

# --- Auth secrets (generate with: openssl rand -base64 32) ---
JWT_SECRET="change-me"
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

# --- ML service (FastAPI) ---
ML_SERVICE_URL="http://localhost:8000"
